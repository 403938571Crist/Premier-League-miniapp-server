# ============================================
# 环境变量模板
# 复制本文件为 .env 后填入实际值，用于本地开发或 CloudBase Run 配置对照
# ============================================

# --------------------------------------------------
# 1. 服务端口（CloudBase Run 会自动注入，本地可忽略）
# --------------------------------------------------
PORT=8080

# --------------------------------------------------
# 2. MySQL 数据库（必填）
# --------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/premierleague?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# --------------------------------------------------
# 3. 外部 API Token（建议填写，否则部分功能降级）
# --------------------------------------------------
# football-data.org API Token（英超积分榜/赛程/球队数据）
# 申请地址: https://www.football-data.org/
FOOTBALL_DATA_TOKEN=

# X (Twitter) API Bearer Token（Romano / X 平台资讯抓取）
# 未配置时自动 fallback 到公开 RSS 源
X_BEARER_TOKEN=

# --------------------------------------------------
# 4. Spring 环境配置（CloudBase Run 部署时通常无需手动设置）
# --------------------------------------------------
# Dockerfile 中已默认设置为 prod，仅在需要覆盖时修改
# SPRING_PROFILES_ACTIVE=prod
