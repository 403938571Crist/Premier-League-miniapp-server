# ============================================
# 环境变量模板
# 复制本文件为 .env 后填入实际值，用于本地开发或 CloudBase Run 配置对照
# 标记 [必填(prod)] 的变量缺失时 prod profile 会启动失败（参见 ProdEnvValidator）
# ============================================

# --------------------------------------------------
# 1. 服务运行时（CloudBase Run 通常会自动注入）
# --------------------------------------------------
PORT=8080
# 容器中已默认 prod；本地跑可改 dev 或留空
# SPRING_PROFILES_ACTIVE=prod

# --------------------------------------------------
# 2. MySQL 数据库
# --------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/premierleague?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
# [必填(prod)] 生产必须设密码；本地无密码可留空
DB_PASSWORD=

# --------------------------------------------------
# 3. 管理端鉴权
# --------------------------------------------------
# [必填(prod)] /api/admin/** 接口的 token；未设置时所有 admin 请求一律 401
# 推荐生成方式：openssl rand -hex 32
# 调用方式（任选其一）：
#   curl -H "X-Admin-Token: <token>" https://your-host/api/admin/stats
#   curl -H "Authorization: Bearer <token>" https://your-host/api/admin/stats
ADMIN_API_TOKEN=

# --------------------------------------------------
# 4. CORS 白名单
# --------------------------------------------------
# 逗号分隔的允许来源（支持 https://*.example.com 通配）；留空 = 拒绝所有浏览器跨源请求
# 微信小程序 wx.request 不走浏览器同源策略，留空对小程序无影响
# 仅在需要开放 H5 / web 管理后台时配置
APP_CORS_ALLOWED_ORIGINS=
# 例：APP_CORS_ALLOWED_ORIGINS=https://admin.example.com,https://*.yourdomain.com

# --------------------------------------------------
# 5. 公开访问基址（用于回链等场景）
# --------------------------------------------------
APP_PUBLIC_BASE_URL=http://localhost:8080

# --------------------------------------------------
# 6. 数据源 API Token（建议填写，否则部分功能降级）
# --------------------------------------------------
# football-data.org（英超积分榜/赛程/球队）—— 免费 10 req/min
# 申请：https://www.football-data.org/
FOOTBALL_DATA_TOKEN=

# API-Football (api-sports.io) —— football-data 被限流时的兜底 provider
# 留空则跳过此 provider；免费档 100 req/天 / 30 req/min
# 申请：https://www.api-football.com/
API_FOOTBALL_KEY=
# 赛季年份（2025 表示 2025-26 赛季）
API_FOOTBALL_SEASON=2025

# X (Twitter) Bearer Token —— Romano 等 X 平台资讯抓取
# 留空则 fallback 到公开 RSS
X_BEARER_TOKEN=

# --------------------------------------------------
# 7. FlareSolverr（可选，绕 Cloudflare）
# --------------------------------------------------
# 仅当需要抓 fbref 等 CF 受保护源时启用
# 启动：docker run -d -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest
FLARESOLVERR_ENABLED=false
FLARESOLVERR_URL=http://localhost:8191/v1

# --------------------------------------------------
# 8. 健康检查心跳（可选）
# --------------------------------------------------
# 配置后服务启动会向此 URL 发心跳（如 healthchecks.io / better-stack）
HEALTHCHECK_PING_URL=
